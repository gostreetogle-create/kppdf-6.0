# KPPDF CRM v6 — environment example (для .env — скопировать и заполнить)

# Postgres (дефолт для docker-compose на Synology DSM)
DATABASE_URL="postgresql://kppdf:kppdf_dev_password@localhost:5432/kppdf_v6?schema=public"

# JWT для аутентификации (минимум 32 символа)
# Сгенерировать: openssl rand -base64 32
JWT_SECRET="change-me-to-32+-chars-random-base64-string"

# Node env
NODE_ENV="development"

# Seed admin
SEED_ADMIN_EMAIL="[email protected]"
SEED_ADMIN_PASSWORD="change-me"

# Optional: nginx upstream port (default 3000)
PORT=3000
