# Database — PostgreSQL-only (Cycle v3.4). NO SQLite fallback.
# Required. Must match the credentials of your PostgreSQL container/instance.
#
# Local dev with kppdf-postgres Docker container:
#   docker run -d --name kppdf-postgres \
#      -e POSTGRES_USER=kppdf \
#      -e POSTGRES_PASSWORD=kppdf123 \
#      -e POSTGRES_DB=kppdf \
#      -p 5432:5432 \
#      postgres:16-alpine
#
# Production: replace ALL three with strong values from your secrets manager.
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DBNAME>?sslmode=disable"

# JWT signing secret (consumed by src/lib/jwt.ts).
# Must be at least 32 characters. Generate fresh random value with:
#   openssl rand -hex 32
# NEVER reuse the dev secret in production.
JWT_SECRET="__generate-with-openssl-rand-hex-32__"

# Optional. Application environment. Auto-detected by `next dev`/`next build`.
# Override only for explicit prod build runs or to suppress the auto-detection.
NODE_ENV="development"
