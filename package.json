    "@mantine/notifications": "^7.13.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "@tabler/icons-react": "^3.21.0",
    "@tanstack/react-query": "^5.59.20",
    "jose": "^5.9.6",
    "next": "16.2.9",
    "pg": "^8.13.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.53.2",
